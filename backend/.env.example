# ============================================================
# Cargo Management System — Backend Environment Variables
# Copy file này thành .env và điền thông tin thực tế
# KHÔNG commit file .env lên Git
# ============================================================

# --- Database ---
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password_here
DB_NAME=cargo_db

# Hoặc dùng URL đầy đủ (ưu tiên hơn nếu deploy cloud)
# DATABASE_URL=mysql+pymysql://root:password@localhost:3306/cargo_db

# --- App ---
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=True

# --- Security ---
SECRET_KEY=your_secret_key_here_change_this_in_production
ACCESS_TOKEN_EXPIRE_MINUTES=60

# --- CORS ---
# Danh sách origins được phép gọi API, cách nhau bằng dấu phẩy
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

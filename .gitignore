# ==========================================
# ENVIRONMENT — NEVER COMMIT
# ==========================================
.env
.env.*
!.env.example

# ==========================================
# PYTHON / BACKEND
# ==========================================
# Virtual environments
venv/
.venv/
env/
ENV/

# Python cache
__pycache__/
*.py[cod]
*.pyo
*.pyd

# Distribution / packaging
*.egg-info/
dist/
build/
*.egg

# pytest / testing
.pytest_cache/
.coverage
htmlcov/

# mypy / type checker
.mypy_cache/
.dmypy.json

# ==========================================
# NODE / FRONTEND (React/Vite)
# ==========================================
node_modules/
dist/
build/
.vite/
frontend/dist/
frontend/build/

# ==========================================
# IDE / EDITORS
# ==========================================
.vscode/
.idea/
*.code-workspace
*.sublime-project
*.sublime-workspace

# ==========================================
# OS FILES
# ==========================================
.DS_Store
Thumbs.db
desktop.ini

# ==========================================
# DATABASE
# ==========================================
*.sqlite3
*.db
*.sql
*.sql.bak

# ==========================================
# LOGS
# ==========================================
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ==========================================
# OPTIONAL (Windows / Python extras)
# ==========================================
*.manifest
*.spec